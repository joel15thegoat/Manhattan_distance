from sklearn.neighbors import NearestNeighbors
import numpy as np

#1. Define your target point and data points Scikit-learn expects 2D arrays, so I will wrap the target point in an extra set of brackets: [[5, 5]]”””
target_point = np.array([[5, 5]]) 
data_points = np.array([[1, 2], [8, 8], [5, 6], [2, 9], [4, 5]])

# 2. Initialize the NearestNeighbors model  Setting metric='manhattan' tells it to calculate city block distance. (Alternatively, you can use the default Minkowski metric and set p=1) ”””
nn = NearestNeighbors(metric='manhattan')

# 3. Fit the model with your dataset
nn.fit(data_points)

# 4. Find the neighbors
“”” I set n_neighbors to the length of the dataset to sort all the points. If you only wanted the top 3, you would set n_neighbors=3. “””
distances, indices = nn.kneighbors(target_point, n_neighbors=len(data_points))

# The results are returned as nested 2D arrays, so I will pull out the first row [0]
distances = distances[0]
indices = indices[0]

# --- Print the Results ---
print(f"Target Point: {target_point[0]}\n")
print("Points sorted by Nearest Neighbor (Manhattan Distance):")
for dist, index in zip(distances, indices):
    # I use the 'index' returned by sklearn to look up the original point
    print(f"Point: {data_points[index]} | Distance: {dist}")
